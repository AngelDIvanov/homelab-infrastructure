# Terraform state — contains sensitive data, never commit
*.tfstate
*.tfstate.backup

# Terraform working files
**/.terraform/
**/.terraform.lock.hcl

# terraform.tfvars contains your SSH key and IPs — use terraform.tfvars.example as a template
terraform/terraform.tfvars
terraform-kubeadm/terraform.tfvars

# Network config contains real IPs — use lab-network-config.example.yaml as a template
kubernetes/monitoring/lab-network-config.yaml

# Python
__pycache__/
*.pyc

# Secrets / session caches
.secrets_cache
.bw_session
*.env
.env*

# Editor
.vscode/
.idea/
*.swp

# Claude Code local settings
**/.claude/

# Generated / binary / internal files
homelab-summary.html
monitoring/grafana/files.zip
scripts/options}
