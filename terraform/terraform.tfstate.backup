            "id": "/var/lib/libvirt/images/k3s-worker-2-cloudinit.iso;e681865e-5532-4961-9a22-1e03bf3ac650",
            "meta_data": "",
            "name": "k3s-worker-2-cloudinit.iso",
            "network_config": "version: 2\nethernets:\n  ens3:\n    dhcp4: false\n    addresses:\n      - 192.168.122.221/24\n    routes:\n      - to: default\n        via: 192.168.122.1\n    nameservers:\n      addresses:\n        - 192.168.122.1\n        - 8.8.8.8\n",
            "pool": "default",
            "user_data": "#cloud-config\n\nhostname: k3s-worker-2\n\nfqdn: k3s-worker-2.homelab.local\n\nmanage_etc_hosts: true\n\nusers:\n\n  - name: andy\n\n    sudo: ALL=(ALL) NOPASSWD:ALL\n\n    groups: users, admin, sudo\n\n    shell: /bin/bash\n\n    lock_passwd: false\n\n    ssh_authorized_keys:\n\n      - ssh-rsa  homelab@ansible\n\n      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILgMILWmBoGWja3vsjUJ1tcRPJg05IFWVuLdOLM77Dda gitlab-runner@ci-runner\n\npackage_update: true\n\npackage_upgrade: false\n\npackages:\n\n  - qemu-guest-agent\n\n  - curl\n\nruncmd:\n\n  - echo 'andy:ubuntu123' | chpasswd\n\n  - sed -i 's/PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config\n\n  - systemctl restart sshd\n\n  - systemctl enable qemu-guest-agent\n\n  - systemctl start qemu-guest-agent\n"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
